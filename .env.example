# ══════════════════════════════════════════════════════════════════════════════
#  Parakh Test Framework — environment configuration template
#
#  1. Copy this file:  cp .env.example .env
#  2. Fill in the values marked  <REQUIRED>  before running tests.
#  3. NEVER commit the real .env file (it is gitignored).
#
#  Priority: shell / CI variables > .env file > defaults in utils/config.py
# ══════════════════════════════════════════════════════════════════════════════

# ── Platform ──────────────────────────────────────────────────────────────────
BASE_URL=https://dev.parakh.civicdataspace.in
ENVIRONMENT=development         # development | staging | production
GRAPHQL_URL=https://dev.api.parakh.civicdataspace.in/graphql/
CDS_URL=https://dev.civicdataspace.in

# ── Keycloak SSO ──────────────────────────────────────────────────────────────
# Leave blank if the app and auth share the same origin.
KEYCLOAK_URL=

# ── Browser ───────────────────────────────────────────────────────────────────
BROWSER=chromium                # chromium | firefox | webkit
HEADLESS=true                   # true | false  (false = watch tests run)
SLOW_MO=0                       # ms delay between Playwright actions (debugging aid)

# ── Viewport ──────────────────────────────────────────────────────────────────
VIEWPORT_WIDTH=1440
VIEWPORT_HEIGHT=900

# ── Timeouts ──────────────────────────────────────────────────────────────────
TIMEOUT=30000                   # element / navigation timeout in ms

# ── Retries ───────────────────────────────────────────────────────────────────
RETRY_COUNT=2                   # number of automatic re-runs on failure
RETRY_DELAY=2.0                 # seconds between retries

# ── Reporting ─────────────────────────────────────────────────────────────────
SCREENSHOT_ON_FAILURE=true      # auto-capture full-page PNG on test failure

# ── Visual regression ─────────────────────────────────────────────────────────
VISUAL_THRESHOLD=0.1            # max allowed pixel-diff % before failing

# ── Auth — primary test account  <REQUIRED for authenticated tests> ───────────
# These map to TestUsers.USER_1 / Config.TEST_EMAIL_1 in the framework.
TEST_EMAIL_1=your-test-account@example.com
TEST_PASSWORD_1=YourTestPassword1!

# ── Auth — secondary test account (parallel / multi-user tests) ───────────────
# A second account avoids state collisions when tests run in parallel.
TEST_EMAIL_2=your-second-account@example.com
TEST_PASSWORD_2=YourTestPassword2!

# ── Sandbox org (required for write-side regression tests) ────────────────────
# Slug of the dedicated sandbox organization that write-marked regression tests
# are allowed to mutate. Leave blank to auto-skip those tests.
SANDBOX_ORG_SLUG=

# ── Known evaluators (deployment-specific data-driven assertions) ─────────────
# Evaluator account emails that some E2E tests assert are present on the
# Evaluators management page. Leave blank to skip those data-driven assertions.
EVALUATOR_EMAIL_1=
EVALUATOR_EMAIL_2=

# ── Auth — convenience aliases (used when only one account is needed) ─────────
# These fall back to the _1 values above if left blank.
# TEST_EMAIL=your-test-account@example.com
# TEST_PASSWORD=YourTestPassword1!

# ── Parallel execution slot ───────────────────────────────────────────────────
# Set to 1 or 2 so each parallel CI job uses a different account.
# Example: CI job 1 sets TEST_USER_INDEX=1, CI job 2 sets TEST_USER_INDEX=2.
TEST_USER_INDEX=1
